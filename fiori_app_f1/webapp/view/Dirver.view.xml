<mvc:View xmlns:core="sap.ui.core" controllerName="com.consapiens.fiori.f1.fioriappf1.controller.Dirver"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <content>
            <Table 
                id="tbl_pilotos"
                inset="false"
                items="{ 
                path: '/DriverSet' }">

                <headerToolbar>
                    <Toolbar id="_IDGenToolbar" >
                        <Title id="_IDGenTitle" text="Listado de Pilotos de Formula 1"/>
                        <ToolbarSpacer id="_IDGenToolbarSpacer" />
                        <Label id="_IDGenLabel" text="Filtrar por: "/>
                        <Select 
                            id="selectFiltro"
                            width="12rem"
                            selectedKey="IdPiloto"
                            change=".onFiltroChange">
                            <items>
                                <core:Item id="_IDGenItem1" key="IdPiloto" text="Número"/>
                                <core:Item id="_IDGenItem2" key="Nombre" text="Nombre"/>
                                <core:Item id="_IDGenItem3" key="Apellidos" text="Apellido"/>
                                <core:Item id="_IDGenItem4" key="Escuderia" text="Escuderia"/>
                                <core:Item id="_IDGenItem5" key="Edad" text="Edad"/>
                                <core:Item id="_IDGenItem6" key="Debut" text="Debut"/>
                                <core:Item id="_IDGenItem7" key="Puntostotales" text="Puntos"/>
                            </items>
                        </Select>

                        <SearchField 
                            id="searchFiltro"
                            width="16rem"
                            placeholder="Escribir el valor a buscar"
                            search=".onFiltroChange"
                            liveChange=".onFiltroChange"
                        />
                    </Toolbar>
                </headerToolbar>

                <columns>
                    <Column id="_IDGenColumn1" >
                        <header>
                            <Button id="btnSortIdPiloto" 
                                text="Número"
                                type="Transparent"
                                press=".onSortColumn">
                                <customData>
                                    <core:CustomData key="sortField" value="IdPiloto"/>
                                </customData>
                            </Button>
                        </header>
                    </Column>
                    <Column id="_IDGenColumn2" >
                        <header>
                            <Button id="btnSortNombre" 
                                text="Nombre"
                                type="Transparent"
                                press=".onSortColumn">
                                <customData>
                                    <core:CustomData key="sortField" value="Nombre"/>
                                </customData>
                            </Button>
                        </header>
                    </Column>
                    <Column id="_IDGenColumn3" >
                        <header>
                            <Button id="btnSortApellido" 
                                text="Apellido"
                                type="Transparent"
                                press=".onSortColumn">
                                <customData>
                                    <core:CustomData key="sortField" value="Apellidos"/>
                                </customData>
                            </Button>
                        </header>
                    </Column>
                    <Column id="_IDGenColumn4" >
                        <header>
                            <Button id="btnSortEdad" 
                                text="Edad"
                                type="Transparent"
                                press=".onSortColumn">
                                <customData>
                                    <core:CustomData key="sortField" value="Edad"/>
                                </customData>
                            </Button>
                        </header>
                    </Column>
                    <Column id="_IDGenColumn5" >
                        <header>
                            <Button id="btnSortDebut" 
                                text="Año debut"
                                type="Transparent"
                                press=".onSortColumn">
                                <customData>
                                    <core:CustomData key="sortField" value="Debut"/>
                                </customData>
                            </Button>
                        </header>
                    </Column>
                    <Column id="_IDGenColumn6" >
                        <header>
                            <Button id="btnSortEscuderia" 
                                text="Escuderia"
                                type="Transparent"
                                press=".onSortColumn">
                                <customData>
                                    <core:CustomData key="sortField" value="Escuderia"/>
                                </customData>
                            </Button>
                        </header>
                    </Column>
                    <Column id="_IDGenColumn7" >
                        <header>
                            <Button id="btnSortPuntos" 
                                text="Puntos totales"
                                type="Transparent"
                                press=".onSortColumn">
                                <customData>
                                    <core:CustomData key="sortField" value="Puntostotales"/>
                                </customData>
                            </Button>
                        </header>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem id="_IDGenColumnListItem1" >
                        <cells>
                            <Text id="_IDGenText7" text="{IdPiloto}"/>
                            <Text id="_IDGenText8" text="{Nombre}"/>
                            <Text id="_IDGenText9" text="{Apellidos}"/>
                            <Text id="_IDGenText10" text="{Edad}"/>
                            <Text id="_IDGenText11" text="{Debut}"/>
                            <Text id="_IDGenText12" text="{Escuderia}"/>
                            <Text id="_IDGenText13" text="{Puntostotales}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>