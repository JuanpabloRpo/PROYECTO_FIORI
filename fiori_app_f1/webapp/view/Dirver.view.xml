<mvc:View xmlns:core="sap.ui.core" controllerName="com.consapiens.fiori.f1.fioriappf1.controller.Dirver"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <content>
            <Table 
                id="tbl_pilotos"
                inset="false"
                items="{ 
                path: '/DriverSet' }">


                <headerToolbar>
                    <Toolbar id="_IDGenToolbar" >
                        <Title id="_IDGenTitle" text="Listado de Pilotos de Formula 1"/>
                        <ToolbarSpacer id="_IDGenToolbarSpacer" />
                        <Button id="_IDGenButton1" 
                        icon="sap-icon://add"
                        type="Transparent"
                        tooltip="Crear piloto"
                        press=".onAbrirCrearPiloto"/>
                        <Label id="_IDGenLabel" text="Filtrar por: "/>
                        <Select 
                            id="selectFiltro"
                            width="12rem"
                            selectedKey="IdPiloto"
                            change=".onFiltroChange">
                            <items>
                                <core:Item id="_IDGenItem1" key="IdPiloto" text="Número"/>
                                <core:Item id="_IDGenItem2" key="Nombre" text="Nombre"/>
                                <core:Item id="_IDGenItem3" key="Apellidos" text="Apellido"/>
                                <core:Item id="_IDGenItem4" key="Escuderia" text="Escuderia"/>
                                <core:Item id="_IDGenItem5" key="Edad" text="Edad"/>
                                <core:Item id="_IDGenItem6" key="Debut" text="Debut"/>
                                <core:Item id="_IDGenItem7" key="Puntostotales" text="Puntos"/>
                            </items>
                        </Select>

                        <SearchField 
                            id="searchFiltro"
                            width="16rem"
                            placeholder="Escribir el valor a buscar"
                            search=".onFiltroChange"
                            liveChange=".onFiltroChange"
                        />
                    </Toolbar>
                </headerToolbar>

                <columns>
                    <Column id="_IDGenColumn1" >
                        <header>
                            <Button id="btnSortIdPiloto" 
                                text="Número"
                                type="Transparent"
                                icon=""
                                iconFirst="false"
                                press=".onSortColumn">
                                <customData>
                                    <core:CustomData key="sortField" value="IdPiloto"/>
                                </customData>
                            </Button>
                        </header>
                    </Column>
                    <Column id="_IDGenColumn2" >
                        <header>
                            <Button id="btnSortNombre" 
                                text="Nombre"
                                type="Transparent"
                                icon=""
                                iconFirst="false"
                                press=".onSortColumn">
                                <customData>
                                    <core:CustomData key="sortField" value="Nombre"/>
                                </customData>
                            </Button>
                        </header>
                    </Column>
                    <Column id="_IDGenColumn3" >
                        <header>
                            <Button id="btnSortApellido" 
                                text="Apellido"
                                type="Transparent"
                                icon=""
                                iconFirst="false"
                                press=".onSortColumn">
                                <customData>
                                    <core:CustomData key="sortField" value="Apellidos"/>
                                </customData>
                            </Button>
                        </header>
                    </Column>
                    <Column id="_IDGenColumn4" >
                        <header>
                            <Button id="btnSortEdad" 
                                text="Edad"
                                type="Transparent"
                                icon=""
                                iconFirst="false"
                                press=".onSortColumn">
                                <customData>
                                    <core:CustomData key="sortField" value="Edad"/>
                                </customData>
                            </Button>
                        </header>
                    </Column>
                    <Column id="_IDGenColumn5" >
                        <header>
                            <Button id="btnSortDebut" 
                                text="Año debut"
                                type="Transparent"
                                icon=""
                                iconFirst="false"
                                press=".onSortColumn">
                                <customData>
                                    <core:CustomData key="sortField" value="Debut"/>
                                </customData>
                            </Button>
                        </header>
                    </Column>
                    <Column id="_IDGenColumn6" >
                        <header>
                            <Button id="btnSortEscuderia" 
                                text="Escuderia"
                                type="Transparent"
                                icon=""
                                iconFirst="false"
                                press=".onSortColumn">
                                <customData>
                                    <core:CustomData key="sortField" value="Escuderia"/>
                                </customData>
                            </Button>
                        </header>
                    </Column>
                    <Column id="_IDGenColumn7" >
                        <header>
                            <Button id="btnSortPuntos" 
                                text="Puntos totales"
                                type="Transparent"
                                icon=""
                                iconFirst="false"
                                press=".onSortColumn">
                                <customData>
                                    <core:CustomData key="sortField" value="Puntostotales"/>
                                </customData>
                            </Button>
                        </header>
                    </Column>
                    <Column id="_IDGenColumn">
                        <Text id="_IDGenText1" text="Acciones"/>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem id="_IDGenColumnListItem1" >
                        <cells>
                            <Text id="_IDGenText7" text="{IdPiloto}"/>
                            <Text id="_IDGenText8" text="{Nombre}"/>
                            <Text id="_IDGenText9" text="{Apellidos}"/>
                            <Text id="_IDGenText10" text="{Edad}"/>
                            <Text id="_IDGenText11" text="{Debut}"/>
                            <Text id="_IDGenText12" text="{Escuderia}"/>
                            <Text id="_IDGenText13" text="{Puntostotales}"/>
                            <HBox id="_IDGenHBox" >
                            <Button id="_IDGenButton" 
                            icon="sap-icon://edit"
                            type="Transparent"
                            tooltip="Editar"
                            press=".onEditarPiloto"/>
                            <Button id="_IDGenButton2"
                                icon="sap-icon://delete"
                                type="Transparent"
                                tooltip="Eliminar"
                                press=".onEliminarPiloto" />
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>

    <Dialog 
        id="dlgCrearPiloto"
        title="Crear Piloto"
        draggable="true"
        resizable="true">
        <VBox id="_IDGenVBox" class="sapuiSmallMargin">
            <Label id="_IDGenLabel1" text="Número"/>
            <Input id="inpCreateIdPiloto" type="Number"/>

            <Label id="_IDGenLabel2" text="Nombre"/>
            <Input id="inpCreateNombre"/>

            <Label id="_IDGenLabel3" text="Apellido"/>
            <Input id="inpCreateApellido"/>

            <Label id="_IDGenLabel4" text="Edad"/>
            <Input id="inpCreateEdad" type="Number"/>

            <Label id="_IDGenLabel5" text="Año debut"/>
            <DatePicker
                id="inpCreateDebut"
                displayFormat="dd MMM yyyy"
                valueFormat="yyyy-MM-dd"
                placeholder="Seleccionar Año"
                change=".onDebutChange"/>

            <Label id="_IDGenLabel6" text="Escuderia"/>
            <Input id="inpCreateEscuderia"/>

            <Label id="_IDGenLabel7" text="Puntos totales"/>
            <Input id="inpCreatePuntos" type="Number"/>
        </VBox>

        <beginButton>
            <Button id="_IDGenButton3" text="Guardar" press=".onCrearPiloto"/>
        </beginButton>

        <endButton>
            <Button id="_IDGenButton4" text="Cancelar" press=".onCancelarCrearPiloto"/>
        </endButton>
    </Dialog>
</mvc:View>